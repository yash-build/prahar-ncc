# SHASTRA — NCC Unit Management System
# .gitignore

# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Environment files — NEVER commit these
.env
client/.env
server/.env
*.env.local
*.env.production

# Build output
client/dist/
client/build/

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Uploads (local dev only)
server/uploads/
